# ===========================================
# Shop Hub Backend — Environment Variables
# Copy this file to .env and fill in values
# ===========================================

# --- Supabase PostgreSQL ---
# Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Use "Transaction" pooler (port 6543) for server apps
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Set true ONLY when developing without Supabase (uses local shophub.db)
USE_SQLITE_FALLBACK=false

# --- Supabase (optional — Storage, future features) ---
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key

# --- Security ---
SECRET_KEY=generate-a-long-random-string-here
ACCESS_TOKEN_EXPIRE_MINUTES=60
ADMIN_REGISTRATION_CODE=SECRET_ADMIN_CODE_123

# --- Gemini AI (https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# --- Server ---
DEBUG=true
SERVER_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
